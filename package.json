{
  "name": "terminal-manager-ui",
  "version": "1.0.0",
  "description": "Web UI for managing multiple Claude Code sessions",
  "main": "dist/server/index.js",
  "scripts": {
    "build:server": "tsc",
    "build:client": "node build.js",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "dev": "npm run build && npm start"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "chokidar": "^3.6.0",
    "express": "^4.18.2",
    "node-pty": "^1.1.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
